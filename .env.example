# Copy this file to .env.local and fill values as needed.
#
# This project currently works with local JSON data by default.
# Add integrations later by setting these environment variables.

NEXT_PUBLIC_SITE_URL=

# Google Analytics (optional)
NEXT_PUBLIC_GA_ID=

# Newsletter subscribe (optional)
# Set SUBSCRIBE_WEBHOOK_URL to store new subscriber emails somewhere (Google Sheets / Zapier / Make / your API).
# If you set SUBSCRIBE_WEBHOOK_SECRET, we will send an HMAC-SHA256 signature header (x-subscribe-signature).
SUBSCRIBE_WEBHOOK_URL=
SUBSCRIBE_WEBHOOK_SECRET=

# If you add Prisma/Postgres later
DATABASE_URL=

# If you add Meilisearch later
MEILISEARCH_HOST=
MEILISEARCH_API_KEY=

