# Copy this file to .env.local and fill values as needed.
#
# This project currently works with local JSON data by default.
# Add integrations later by setting these environment variables.

NEXT_PUBLIC_SITE_URL=

# Google Analytics (optional)
NEXT_PUBLIC_GA_ID=

# Coupang Partners banners (optional)
# Use affiliate links and your own hosted banner images (do NOT put API secrets in client env).
NEXT_PUBLIC_COUPANG_LEFT_URL=
NEXT_PUBLIC_COUPANG_LEFT_IMG=
NEXT_PUBLIC_COUPANG_RIGHT_URL=
NEXT_PUBLIC_COUPANG_RIGHT_IMG=
NEXT_PUBLIC_COUPANG_MOBILE_URL=
NEXT_PUBLIC_COUPANG_MOBILE_IMG=

# Coupang Partners widget (optional)
# Side rails: e.g. 120x600 carousel (NEXT_PUBLIC_COUPANG_WIDGET_ID).
# Mobile bottom bar: set NEXT_PUBLIC_COUPANG_MOBILE_WIDGET_ID if you have a separate horizontal widget.
NEXT_PUBLIC_COUPANG_WIDGET_ID=
NEXT_PUBLIC_COUPANG_MOBILE_WIDGET_ID=
NEXT_PUBLIC_COUPANG_TRACKING_CODE=
NEXT_PUBLIC_COUPANG_TEMPLATE=carousel

# Newsletter subscribe (optional)
# Set SUBSCRIBE_WEBHOOK_URL to store new subscriber emails somewhere (Google Sheets / Zapier / Make / your API).
# If you set SUBSCRIBE_WEBHOOK_SECRET, we will send an HMAC-SHA256 signature header (x-subscribe-signature).
SUBSCRIBE_WEBHOOK_URL=
SUBSCRIBE_WEBHOOK_SECRET=

# If you add Prisma/Postgres later
DATABASE_URL=

# If you add Meilisearch later
MEILISEARCH_HOST=
MEILISEARCH_API_KEY=

